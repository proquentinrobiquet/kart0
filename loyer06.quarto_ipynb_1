        "#Ce code permet de préparer les données INSEE et géométries. Donc de réaliser les jointures nécessaires, voir le fichier d'origine pour plus de détails.\n",
        "\n",
        "os.chdir(r\"C:\\Users\\FlowUP\\Desktop\\SIG\\Loyers de france\")\n",
        "loyer_fr=pd.read_excel(r\"C:\\Users\\FlowUP\\Desktop\\SIG\\Loyers de france\\pred-app-mef-dhup.xlsx\",dtype={'INSEE_C':\"string\"})\n",
        "\n",
        "#charger des communes de france\n",
        "com_fr=gpd.read_file(\"communes_fr.gpkg\",layer=\"commune\")\n",
        "\n",
        "#regarder comment est composer le loyer_fr pour savoir les champs possibles de jointure\n",
        "#selectionner seuelment les departements du 06 dans la variable des loyers\n",
        "loyer06=loyer_fr[loyer_fr[\"DEP\"]==\"06\"]\n",
        "\n",
        "#permet de renommer une colonne qui avait un nom trop long\n",
        "com_fr=com_fr.rename(columns={\"code_insee_du_departement\":\"dep_code_insee\"})\n",
        "\n",
        "#selection dans le gpkg commune du departement 06\n",
        "com06=com_fr[com_fr[\"dep_code_insee\"]==\"06\"]\n",
        "\n",
        "#allegement par selection des colonnes necessaires\n",
        "\n",
        "light_com06=com06[[\"nom_officiel\",\"code_insee\",\"population\",\"superficie_cadastrale\",\"geometry\",\"dep_code_insee\"]]\n",
        "light_loyer06=loyer06[[\"DEP\",\"INSEE_C\",\"LIBGEO\",\"loypredm2\",\"nbobs_com\",\"nbobs_mail\",\"lwr.IPm2\",\"upr.IPm2\"]]\n",
        "map_loyer=light_com06.merge(light_loyer06,left_on=\"code_insee\",right_on=\"INSEE_C\",how=\"left\")"
