      "source": [
        "#| echo: false\n",
        "\n",
        "#Ce code permet de préparer les données INSEE et géométries. Donc de réaliser les jointures nécessaires, voir le fichier d'origine pour plus de détails.\n",
        "\n",
        "os.chdir(r\"C:/Users/FlowUP/Desktop/SIG/QUARTO/Website\")\n",
        "\n",
        "map_loyer=gpd.read_file(\"loyers_AM.gpkg\",layer=\"communes\")"
      ],
      "id": "5d6926e8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "\n",
        "for m2 in [15, 30, 50, 100, 150, 200]:\n",
        "    map_loyer[\"loym2perso\"] = map_loyer[\"upr.IPm2\"].astype(int) * m2\n",
        "\n",
        "    m = map_loyer.explore(\n",
        "        column=\"loym2perso\",\n",
        "        scheme=\"naturalbreaks\",\n",
        "        k=7,\n",
        "        cmap=\"BuPu\",\n",
        "        tooltip=[\"nom_officiel\", \"loym2perso\", \"nbobs_com\"],\n",
        "        popup=True,\n",
        "        legend_kwds=dict(colorbar=False),\n",
        "        style_kwds=dict(color=\"black\", weight=0.8, fillOpacity=0.7)\n",
        "    )\n",
        "\n",
        "    # Sauvegarde la carte\n",
        "    m.save(f\"_site/carte_{m2}.html\")"
      ],
